# ──────────────────────────────────────────────
# PII Ghost-Hunter · Environment Variables
# Copy to .env and fill in values. Never commit .env.
# ──────────────────────────────────────────────

# ─── Kafka ───────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
# For production (SSL):
# KAFKA_SECURITY_PROTOCOL=SSL
# KAFKA_SSL_CA_LOCATION=/certs/ca.pem
# KAFKA_SSL_CERT_LOCATION=/certs/client.pem
# KAFKA_SSL_KEY_LOCATION=/certs/client.key

# ─── Airflow ─────────────────────────────────
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@localhost:5432/airflow
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__WEBSERVER__SECRET_KEY=

# ─── AWS ─────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_DATA_LAKE_BUCKET=pii-hunter-datalake
S3_QUARANTINE_BUCKET=pii-quarantine
S3_MODELS_BUCKET=pii-hunter-models

# ─── Database ────────────────────────────────
DATABASE_URL=postgresql+asyncpg://airflow:airflow@localhost:5432/pii_hunter
REDIS_URL=redis://localhost:6379/0

# ─── ML ──────────────────────────────────────
MODEL_CONFIDENCE_THRESHOLD=0.85
MODEL_S3_PATH=s3://pii-hunter-models/latest/model.tar.gz

# ─── Notifications ───────────────────────────
DPO_EMAIL=dpo@yourcompany.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ─── Auth ────────────────────────────────────
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
