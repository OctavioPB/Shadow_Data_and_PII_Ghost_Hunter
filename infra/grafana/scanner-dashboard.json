{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "PII Ghost-Hunter — Scanner Pipeline",
  "uid": "pii-scanner",
  "tags": ["pii", "scanner", "kafka"],
  "timezone": "utc",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Events Consumed / min",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0 }
            ]
          },
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(rate(scanner_events_consumed_total[1m])) * 60",
          "legendFormat": "events/min",
          "datasource": "${DS_PROMETHEUS}"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "DLQ Events (last 1 h)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(increase(scanner_events_dlq_total[1h]))",
          "legendFormat": "DLQ events",
          "datasource": "${DS_PROMETHEUS}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Processing Latency p95",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "red", "value": 2.0 }
            ]
          },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(scanner_event_processing_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "datasource": "${DS_PROMETHEUS}"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Processing Latency p99",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1.0 },
              { "color": "red", "value": 5.0 }
            ]
          },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(scanner_event_processing_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "datasource": "${DS_PROMETHEUS}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Events Consumed by Topic",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (topic) (rate(scanner_events_consumed_total[1m])) * 60",
          "legendFormat": "{{topic}}",
          "datasource": "${DS_PROMETHEUS}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "DLQ Events by Topic",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "#E03448", "mode": "fixed" },
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "sum by (topic) (rate(scanner_events_dlq_total[1m])) * 60",
          "legendFormat": "{{topic}} DLQ",
          "datasource": "${DS_PROMETHEUS}"
        }
      ]
    },
    {
      "id": 7,
      "type": "heatmap",
      "title": "Event Processing Latency Distribution",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "options": {
        "calculate": false,
        "yAxis": { "unit": "s" },
        "color": { "scheme": "Blues" }
      },
      "targets": [
        {
          "expr": "sum(rate(scanner_event_processing_seconds_bucket[5m])) by (le)",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "datasource": "${DS_PROMETHEUS}"
        }
      ]
    }
  ],
  "annotations": {
    "list": [
      {
        "name": "Deployments",
        "datasource": "${DS_PROMETHEUS}",
        "enable": true,
        "hide": false,
        "iconColor": "#C8982A",
        "expr": "changes(process_start_time_seconds{job=\"pii-scanner\"}[2m]) > 0",
        "titleFormat": "Scanner restart"
      }
    ]
  }
}
